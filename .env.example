# Copy this file to .env and update the values for your local setup.
# Any variable marked as optional can be left blank unless you plan to
# use the associated integration.

# Connection string for the PostgreSQL instance used by the app.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgres://postgres:postgres@localhost:5432/merchant"

# Port the Express + Vite server should listen on. Defaults to 5000.
#PORT=5000

# API tokens for optional data providers.
#DISCOGS_API_TOKEN=
#COINAPI_KEY=
#ALPHA_VANTAGE_KEY=

# Environment flags primarily used in hosted environments like Replit.
#NODE_ENV=development
#REPL_ID=
